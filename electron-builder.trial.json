{
  "appId": "com.viana.transporte.trial.v2",
  "productName": "Viana Transporte Trial",
  "artifactName": "Viana-Transporte-Trial-${version}-${os}-${arch}.${ext}",
  "files": [
    "out/**/*",
    "package.json"
  ],
  "directories": {
    "output": "dist/trial",
    "buildResources": "build"
  },
  "publish": {
    "provider": "github",
    "owner": "AriSilva94",
    "repo": "Viana-Transporte",
    "channel": "trial"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "executableName": "VianaTransporteTrial",
    "icon": "build/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico"
  }
}
