{
  "name": "mightyrept",
  "version": "1.0.0",
  "description": "Earthmoving management desktop application",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:full": "npm run db:seed:generate && cross-env DIST_PROFILE=full electron-vite build",
    "build:trial": "npm run db:seed:generate && cross-env DIST_PROFILE=trial electron-vite build",
    "dist:win:full": "npm run build:full && npx electron-builder --win --x64 --dir --config.directories.output=dist/full --config.win.signAndEditExecutable=false",
    "dist:win:trial": "npm run build:trial && npx electron-builder --win --x64 --dir --config.directories.output=dist/trial --config.productName=MightyReptTrial --config.appId=com.mightyrept.trial --config.win.executableName=MightyReptTrial --config.win.signAndEditExecutable=false",
    "dist:win:all": "npm run dist:win:full && npm run dist:win:trial",
    "preview": "electron-vite preview",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed:generate": "node scripts/generate-financial-seed.cjs",
    "db:sync:excel": "node scripts/sync-db-from-excel.cjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@radix-ui/react-slot": "^1.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "drizzle-orm": "^0.30.8",
    "i18next": "^24.2.3",
    "lucide-react": "^0.363.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^15.7.4",
    "react-router-dom": "^6.22.3",
    "tailwind-merge": "^2.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.73",
    "@types/react-dom": "^18.2.23",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "drizzle-kit": "^0.20.17",
    "cross-env": "^7.0.3",
    "electron": "^41.1.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^2.1.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.48.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.4.3",
    "vitest": "^2.1.9",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.mightyrept.app",
    "productName": "MightyRept",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "src/main/db/migrations",
        "to": "migrations"
      },
      {
        "from": "src/main/db/seeds",
        "to": "seeds"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "executableName": "MightyRept",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
